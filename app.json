{
  "expo": {
    "name": "AvoCook",
    "slug": "avocook",
    "scheme": "avocook",
    "version": "2.0.0",
    "orientation": "default",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#F7F3EA",
      "dark": {
        "image": "./assets/logo-dark.png",
        "backgroundColor": "#10201D"
      }
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "org.epimac.avocook",
      "icon": {
        "light": "./assets/icon.png",
        "dark": "./assets/icon-dark.png"
      },
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "UIRequiresFullScreen": false,
        "CFBundleAllowMixedLocalizations": true,
        "NSLocalNetworkUsageDescription": "Autoriser l'accès au réseau local uniquement pour se connecter à un serveur Nextcloud hébergé sur votre réseau.",
        "NSPhotoLibraryUsageDescription": "Autoriser l'accès aux photos pour ajouter une image à une recette.",
        "NSPhotoLibraryAddUsageDescription": "Autoriser l'enregistrement d'images de recettes si nécessaire."
      }
    },
    "android": {
      "package": "app.avocook.mobile",
      "permissions": [],
      "blockedPermissions": [
        "android.permission.RECORD_AUDIO"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F7F3EA"
      }
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      "expo-sqlite",
      [
        "expo-localization",
        {
          "supportedLocales": {
            "ios": [
              "fr",
              "en",
              "de",
              "es",
              "it"
            ],
            "android": [
              "fr",
              "en",
              "de",
              "es",
              "it"
            ]
          }
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#F7F3EA",
          "image": "./assets/logo.png",
          "imageWidth": 220,
          "resizeMode": "contain",
          "dark": {
            "backgroundColor": "#10201D",
            "image": "./assets/logo-dark.png"
          }
        }
      ],
      "expo-notifications",
      [
        "expo-image-picker",
        {
          "photosPermission": "Autoriser l'accès aux photos pour ajouter une image à une recette.",
          "cameraPermission": false,
          "microphonePermission": false
        }
      ],
      "./plugins/withAndroidNetworkSecurity",
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "71346d2a-c2f5-4f0e-a01e-544bfc1f66ca"
      }
    },
    "owner": "logarex"
  }
}
